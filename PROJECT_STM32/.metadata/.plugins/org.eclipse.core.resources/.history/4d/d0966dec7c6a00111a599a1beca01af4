void BMP280_writeReg(uint8_t reg_add,uint8_t data)
{
	uint8_t tx[2];
	tx[0] = reg_add & 0x7F;   // 7th bit determine write or read so write = 0
	tx[1] = data;

	BMP280_CS_LOW();
	HAL_SPI_Transmit(&hspi1, tx, 2, HAL_MAX_DELAY);
	BMP280_CS_HIGH();
}


void BMP280_ReadChip_id()
{
	uint8_t chip_id;
	uint8_t reg = (0xD0|0x80);
	HAL_GPIO_WritePin(GPIOA, GPIO_PIN_4, GPIO_PIN_RESET);

	HAL_SPI_Transmit(&hspi1, &reg, 1, 100);

	HAL_SPI_Receive(&hspi1, &chip_id, 1, 100);

	HAL_GPIO_WritePin(GPIOA, GPIO_PIN_4, GPIO_PIN_SET);

	char arr[50];

	sprintf(arr,"ID=%X\r\n",chip_id);

	HAL_UART_Transmit(&huart2,(uint8_t*)arr,strlen(arr),100);

    HAL_Delay(1000);

}

void BMP280_ReadRegs(uint8_t reg,uint8_t* pdata,uint8_t len)
{
	uint8_t reg_add = (reg |0x80);

	BMP280_CS_LOW();

	HAL_SPI_Transmit(&hspi1, &reg_add,1, HAL_MAX_DELAY);
	HAL_SPI_Receive(&hspi1, pdata, len, HAL_MAX_DELAY);

	BMP280_CS_HIGH();
}

int32_t BMP280_ReadTempADC(void)
{
    uint8_t temp_data[3];

    BMP280_ReadRegs(0xFA, temp_data, 3);

    return ((int32_t)temp_data[0] << 12) |
           ((int32_t)temp_data[1] << 4)  |
           ((int32_t)temp_data[2] >> 4);
}




uint16_t dig_T1;
int16_t  dig_T2;
int16_t  dig_T3;

void BMP280_ReadCalibration(void)
{
    uint8_t calib[6];

    BMP280_ReadRegs(0x88, calib, 6);

    dig_T1 = (calib[1] << 8) | calib[0];
    dig_T2 = (calib[3] << 8) | calib[2];
    dig_T3 = (calib[5] << 8) | calib[4];
}



int32_t t_fine;

float BMP280_CompensateTemp(int32_t adc_T)
{
    int32_t var1, var2;

    var1 = ((((adc_T >> 3) -
             ((int32_t)dig_T1 << 1))) *
             ((int32_t)dig_T2)) >> 11;

    var2 = (((((adc_T >> 4) -
             ((int32_t)dig_T1)) *
             ((adc_T >> 4) -
             ((int32_t)dig_T1))) >> 12) *
             ((int32_t)dig_T3)) >> 14;

    t_fine = var1 + var2;

    return ((t_fine * 5 + 128) >> 8) / 100.0f;
}

