#include "stm32_f446xx.h"
#include "stm32_f446xx_gpio_driver.h"

int main()
{

GPIO_Handle_t GpioLed, GpioIntr;

/* configurations for led */
GpioLed.pGPIOx = GPIOA;
GpioLed.GPIO_PinConfig.GPIO_PinNumber = GPIO_PIN_NO_5;
GpioLed.GPIO_PinConfig.GPIO_PinMode = GPIO_MODE_OUTPUT;
GpioLed.GPIO_PinConfig.GPIO_PinSpeed = GPIO_SPEED_LOW;
GpioLed.GPIO_PinConfig.GPIO_PinOPType = 0;
GpioLed.GPIO_PinConfig.GPIO_PinPuPdControl = GPIO_PUPD_NO;

GPIO_PericClockControl(GPIOA, ENABLE);

GPIO_Init(&GpioLed);

/* configurations for interrupt (user button) */
GpioIntr.pGPIOx = GPIOC;
GpioIntr.GPIO_PinConfig.GPIO_PinNumber = GPIO_PIN_NO_13;
GpioIntr.GPIO_PinConfig.GPIO_PinMode = GPIO_MODE_IT_FT;
GpioIntr.GPIO_PinConfig.GPIO_PinSpeed = GPIO_SPEED_FAST;
GpioIntr.GPIO_PinConfig.GPIO_PinPuPdControl = GPIO_PULL_UP;

GPIO_PericClockControl(GPIOC, ENABLE);

GPIO_Init(&GpioIntr);

GPIO_IRQInterruptConfig(IRQ_NO_EXTI15_10,ENABLE);
}
